{
  // Папка сборки CMake
  "cmake.buildDirectory": "${workspaceFolder}/build",

  // Настройки конфигурации CMake
  "cmake.configureSettings": {
    "CMAKE_BUILD_TYPE": "Debug",
    "CMAKE_PREFIX_PATH": "C:/Qt/6.8.0/mingw_64/lib/cmake",
    "CMAKE_CXX_COMPILER": "C:/Qt/Tools/mingw1310_64/bin/g++.exe",
    "CMAKE_C_COMPILER": "C:/Qt/Tools/mingw1310_64/bin/gcc.exe"
  },

  // Qt расширение (для .ui, qmake, Designer)
  "qt.qmake.path": "C:/Qt/6.8.0/mingw_64/bin/qmake.exe",
  "qt.qtPath": "C:/Qt/6.8.0/mingw_64",

  // Чтобы IntelliSense видел настройки сборки
  "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",

  "files.associations": {
    "*.ui": "qtcreator"
  },
  "editor.defaultFormatter": null,
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}

